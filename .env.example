# ============================================================
# DPS-Superskills MCP Server — .env configuration
# Copy this file to .env and fill in the values.
# ============================================================

# ── Transport ──────────────────────────────────────────────
# stdio: for local IDE use (Claude Desktop, Cursor, Antigravity)
# http:  for network/remote access
TRANSPORT_DRIVER=stdio

# ── Storage ────────────────────────────────────────────────
# fs: local filesystem (recommended for local use)
# memory: no persistence (for testing)
# redis: for production multi-tenant deployments
STORAGE_DRIVER=fs

# ── Plugins ────────────────────────────────────────────────
# Default already loads all first-party plugins:
#   system.tool.*    — health/system tools
#   skills.tool.*    — skill_list, skill_read, skill_run, skill_dispatch
#   knowledge.tool.* — kb_write, kb_query, kb_health
# Only override this if you want to disable specific tools.
#   code_index.tool.* — code_search, code_index, code_index_status (local code retrieval)
#   dps.tool.*        — dps_init, dps_check (DPS living-spec inject + validate; dps_check needs SAFE_MODE=false)
MCP_PLUGIN_ALLOWLIST=system.tool.ts,system.tool.js,skills.tool.ts,skills.tool.js,knowledge.tool.ts,knowledge.tool.js,code_index.tool.ts,code_index.tool.js,dps.tool.ts,dps.tool.js

# Plugin isolation: "policy" = trust built-ins in-process (recommended for local)
# "external" = sandbox non-built-in plugins in child processes
MCP_PLUGIN_ISOLATION_MODE=policy

# ── Skills Path ────────────────────────────────────────────
# Optional: override the default skills directory path.
# Default: <project_root>/docs/DPS-superskills-v5.2.1
# MCP_SKILLS_PATH=/home/ybao/B.1/DPS-Superskills/docs/DPS-superskills-v5.2.1

# ── Code retrieval & DPS spec (data plane) ─────────────────
# Project root the indexer + DPS tools operate on. Empty => process.cwd() under
# stdio. Set this if your IDE does not launch the server with the project as cwd.
# MCP_WORKSPACE_ROOT=/abs/path/to/your/project
# Set false to stop code_search auto-building the index on first use.
MCP_INDEX_AUTO=true

# ── Project Identity ───────────────────────────────────────
MCP_PROJECT_ID=dps-superskills
MCP_TENANT_ID=tenant_local

# ── Security ───────────────────────────────────────────────
MCP_SAFE_MODE=true

# ── HTTP mode (only needed when TRANSPORT_DRIVER=http) ─────
# HTTP_HOST=127.0.0.1
# HTTP_PORT=3333
# MCP_AUTH_MODE=api_key
# MCP_API_KEY=<generate-a-random-string-at-least-32-chars>
# ALLOWED_ORIGINS=http://localhost:3000
# ALLOWED_HOSTS=localhost,127.0.0.1

# ── MCP Resources ──────────────────────────────────────────
# Expose skills as MCP Resources at skill://<name> (default: true).
# Clients can auto-inject DISCIPLINE skills into context without tool calls.
# Set to false to disable the Resources endpoint entirely.
# MCP_ENABLE_SKILL_RESOURCES=true

# ── Telemetry ──────────────────────────────────────────────
# stdio mode: stderr (default, required — stdout is reserved for MCP frames)
# http mode: file (writes to .mcp-telemetry/)
# TELEMETRY_DRIVER=stderr
